---
// サイト全体の共通レイアウト。
// TODO(head内): AdSense審査時にサイト全体タグ <script async src="https://pagead2.googlesyndication.com/..."> を追加
// TODO(head内): OGPメタタグ / アクセス解析（Cloudflare Web Analytics）を追加
// ※HTMLコメントは出力に残るため、TODOはこのfrontmatter側に書く
import ThemeToggle from "../components/ThemeToggle.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  robots?: string;
}
const {
  title,
  description = "AIプロダクトの設計と実装を、作って学んだ記録",
  robots,
} = Astro.props;
const SITE_NAME = "kinakomochio.dev"; // 仮。正式決定したら変更
const { pathname } = Astro.url;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | {SITE_NAME}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE_NAME}
      href="/rss.xml"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+JP:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <!-- テーマのちらつき(FOUC)防止: 描画前に data-theme を確定させる -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const theme =
          stored ||
          (matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light");
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body
    class="m-0 bg-[var(--bg)] font-['IBM_Plex_Sans_JP',system-ui,sans-serif] text-[var(--fg)] [line-height:1.8]"
  >
    <header
      class="flex items-center justify-between border-b border-[var(--line)] px-10 py-[22px]"
    >
      <a
        class="flex items-center gap-[10px] font-['IBM_Plex_Mono',monospace] text-[15px] font-semibold no-underline hover:text-[var(--fg)]"
        href="/"
      >
        <span
          class="inline-flex h-[10px] w-[10px] rounded-sm bg-[var(--accent)]"
          aria-hidden="true"></span>
        ~/kinakomochio.dev
      </a>
      <div class="flex items-center gap-[22px]">
        <nav
          class="flex gap-[18px] font-['IBM_Plex_Mono',monospace] text-[13px]"
        >
          <a
            class="text-[var(--muted)] no-underline hover:text-[var(--fg)] aria-[current=page]:text-[var(--accent)]"
            href="/"
            aria-current={pathname === "/" ? "page" : undefined}>home</a
          >
          <a
            class="text-[var(--muted)] no-underline hover:text-[var(--fg)] aria-[current=page]:text-[var(--accent)]"
            href="/about"
            aria-current={pathname === "/about/" ? "page" : undefined}>about</a
          >
          <a
            class="text-[var(--muted)] no-underline hover:text-[var(--fg)] aria-[current=page]:text-[var(--accent)]"
            href="/contact"
            aria-current={pathname === "/contact/" ? "page" : undefined}
            >contact</a
          >
        </nav>
        <ThemeToggle />
      </div>
    </header>
    <main class="mx-auto max-w-[680px] px-10 pt-12 pb-[60px]">
      <slot />
    </main>
    <footer
      class="mx-auto flex max-w-[680px] justify-between border-t border-[var(--line)] px-10 pt-5 pb-8 font-['IBM_Plex_Mono',monospace] text-xs text-[var(--muted)]"
    >
      <span>© {new Date().getFullYear()} kinakomochio</span>
      <div class="flex gap-4">
        <a class="text-[var(--muted)] no-underline" href="/rss.xml">rss</a>
        <a class="text-[var(--muted)] no-underline" href="/privacy">privacy</a>
      </div>
    </footer>
  </body>
</html>
