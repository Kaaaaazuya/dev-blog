---
// サイト全体の共通レイアウト。デザインは後で詰める（現状は最小限）。
// TODO(head内): AdSense審査時にサイト全体タグ <script async src="https://pagead2.googlesyndication.com/..."> を追加
// TODO(head内): OGPメタタグ / アクセス解析（Cloudflare Web Analytics）を追加
// ※HTMLコメントは出力に残るため、TODOはこのfrontmatter側に書く
interface Props {
  title: string;
  description?: string;
  robots?: string;
}
const {
  title,
  description = "AIプロダクトの設計と実装を、作って学んだ記録",
  robots,
} = Astro.props;
const SITE_NAME = "kinakomochio.dev"; // 仮。正式決定したら変更
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | {SITE_NAME}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE_NAME}
      href="/rss.xml"
    />
  </head>
  <body>
    <header>
      <nav>
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/privacy">Privacy</a>
        <a href="/contact">Contact</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>
        © {new Date().getFullYear()} Kinakomochio — <a href="/privacy"
          >プライバシーポリシー</a
        >
      </p>
    </footer>
  </body>
</html>

<style is:global>
  /* 最小限のスタイル。テーマ/デザインは未決事項（docs/architecture.md） */
  body {
    max-width: 760px;
    margin: 0 auto;
    padding: 1rem;
    font-family: sans-serif;
    line-height: 1.8;
  }
  nav {
    display: flex;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid #ddd;
  }
  footer {
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid #ddd;
    font-size: 0.85rem;
  }
  pre {
    padding: 1rem;
    overflow-x: auto;
    border-radius: 6px;
  }
</style>
