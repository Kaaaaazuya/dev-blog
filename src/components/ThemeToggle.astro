---
// ダークモード切替ボタン。localStorageに保存し、BaseLayoutのFOUC防止スクリプトと対になる。
---

<button
  id="theme-toggle"
  aria-label="テーマ切替"
  type="button"
  class="flex h-[34px] w-[34px] cursor-pointer items-center justify-center rounded-md border border-[var(--line)] bg-transparent text-[var(--fg)] hover:border-[var(--accent)]"
>
  <svg
    class="icon-sun hidden [html[data-theme=dark]_&]:block"
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
  >
    <circle cx="12" cy="12" r="4.2"></circle>
    <path
      d="M12 2.5v2.6M12 18.9v2.6M2.5 12h2.6M18.9 12h2.6M4.8 4.8l1.9 1.9M17.3 17.3l1.9 1.9M19.2 4.8l-1.9 1.9M6.7 17.3l-1.9 1.9"
    ></path>
  </svg>
  <svg
    class="icon-moon block [html[data-theme=dark]_&]:hidden"
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
  >
    <path d="M20 13.2A8.2 8.2 0 0 1 10.8 4a8.2 8.2 0 1 0 9.2 9.2Z"></path>
  </svg>
</button>

<script is:inline>
  (function () {
    const btn = document.getElementById("theme-toggle");
    btn.addEventListener("click", function () {
      const current = document.documentElement.getAttribute("data-theme");
      const next = current === "dark" ? "light" : "dark";
      document.documentElement.setAttribute("data-theme", next);
      localStorage.setItem("theme", next);
    });
  })();
</script>
