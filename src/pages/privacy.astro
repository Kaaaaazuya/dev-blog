---
import BaseLayout from "../layouts/BaseLayout.astro";
// TODO: AdSense審査前に必ず正式な文面にする。
//  - パーソナライズ広告の無効化リンク（Google広告設定）を記載
//  - 使用する解析ツール（Cloudflare Web Analytics 等）を記載
//  - 免責事項を記載
---

<BaseLayout title="プライバシーポリシー">
  <h1 class="mb-6 text-[22px] font-bold">プライバシーポリシー</h1>
  <h2 class="mt-0 mb-3 text-base font-semibold">広告配信について</h2>
  <p class="m-0 text-[14.5px] leading-[1.95] text-[var(--muted)]">
    当サイトは第三者配信の広告サービス（Google
    AdSense）を利用予定です。広告配信事業者は Cookie
    を使用し、ユーザーの興味に応じた広告を表示することがあります。
  </p>
  <h2 class="mt-8 mb-3 text-base font-semibold">アクセス解析について</h2>
  <p class="m-0 text-[14.5px] leading-[1.95] text-[var(--muted)]">準備中</p>
  <h2 class="mt-8 mb-3 text-base font-semibold">免責事項</h2>
  <p class="m-0 text-[14.5px] leading-[1.95] text-[var(--muted)]">準備中</p>
</BaseLayout>
