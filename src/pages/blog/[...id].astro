---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import AdSlot from "../../components/AdSlot.astro";
import { includeDrafts } from "../../lib/blog-filter";

export async function getStaticPaths() {
  // 本番はdraft除外、dev/PRプレビューではdraftも表示する
  const posts = await getCollection(
    "blog",
    ({ data }) => includeDrafts || !data.draft,
  );
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const AUTHOR_NAME = "kinakomochio";
const SITE_URL = Astro.site ?? "https://kinakomochio.yk3kzy.workers.dev";

// Build JSON-LD BlogPosting schema
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: {
    "@type": "Person",
    name: AUTHOR_NAME,
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": new URL(`/blog/${post.id}/`, SITE_URL).toString(),
  },
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  jsonLd={jsonLd}
>
  <article>
    <p
      class="mb-[14px] font-['IBM_Plex_Mono',monospace] text-[12.5px] text-[var(--muted)]"
    >
      {
        post.data.series && (
          <>
            <a
              class="text-[var(--accent)] no-underline"
              href={`/?series=${post.data.series}`}
            >
              {post.data.series}
            </a>
            {" · "}
          </>
        )
      }
      <time datetime={post.data.pubDate.toISOString()}>
        {post.data.pubDate.toISOString().slice(0, 10)}
      </time>
      {
        post.data.updatedDate &&
          post.data.updatedDate.getTime() !== post.data.pubDate.getTime() && (
            <>
              {" 公開（"}
              <time datetime={post.data.updatedDate.toISOString()}>
                {post.data.updatedDate.toISOString().slice(0, 10)}
              </time>
              {" 更新）"}
            </>
          )
      }
      {!post.data.updatedDate && " 公開"}
    </p>
    <h1 class="mb-4 text-[25px] leading-[1.65] font-bold tracking-[-0.01em]">
      {post.data.title}
    </h1>
    {
      post.data.tags.length > 0 && (
        <div class="mb-10 flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <span class="rounded-full border border-[var(--line)] px-[10px] py-[3px] font-['IBM_Plex_Mono',monospace] text-[11.5px] text-[var(--accent)] no-underline">
              {tag}
            </span>
          ))}
        </div>
      )
    }

    <AdSlot slot="TODO-上部ユニットID" />

    <div class="prose">
      <Content />
    </div>

    <AdSlot slot="TODO-下部ユニットID" />
  </article>
</BaseLayout>

<style>
  /* markdown由来の要素はクラスを持たないため、ここだけ素のCSSでトークンを適用する */
  .prose :global(h2) {
    margin: 0 0 16px;
    padding-top: 8px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 18.5px;
    font-weight: 600;
    line-height: 1.7;
  }
  .prose :global(h2)::before {
    content: "##";
    font:
      600 13px "IBM Plex Mono",
      monospace;
    color: var(--accent);
  }
  .prose :global(p) {
    margin: 0 0 20px;
    font-size: 15px;
    line-height: 2.05;
  }
  .prose :global(a) {
    color: var(--accent);
    text-underline-offset: 3px;
  }
  .prose :global(blockquote) {
    margin: 0 0 32px;
    padding: 14px 20px;
    border: 1px solid var(--line);
    border-left: 2px solid var(--accent);
    border-radius: 0 8px 8px 0;
    background: var(--surface);
    color: var(--muted);
    font-size: 14px;
    line-height: 2;
  }
  .prose :global(pre) {
    margin: 0 0 32px;
    padding: 18px 20px;
    background: var(--code);
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow-x: auto;
    font:
      13px/1.75 "IBM Plex Mono",
      monospace;
  }
  .prose :global(code) {
    font-family: "IBM Plex Mono", monospace;
  }
  .prose :global(:not(pre) > code) {
    font-size: 0.88em;
    background: var(--code);
    border-radius: 5px;
    padding: 2px 6px;
  }
</style>

<script>
  // mermaid ブロックがあるページだけ動的import（チャンク分割されるので他ページに影響なし）
  const blocks = document.querySelectorAll<HTMLElement>("pre.mermaid");
  if (blocks.length > 0) {
    const { default: mermaid } = await import("mermaid");
    mermaid.initialize({ startOnLoad: false, theme: "neutral" });
    await mermaid.run({ nodes: [...blocks] });
  }
</script>
