---
import BaseLayout from "../layouts/BaseLayout.astro";
// TODO: Google Forms作成後、下記 GOOGLE_FORM_EMBED_URL に埋め込み用URL
// （フォーム編集画面の「送信」→「埋め込み<>」で取得できるURL）を設定する。
const GOOGLE_FORM_EMBED_URL = "";
---

<BaseLayout title="お問い合わせ">
  <h1 class="mb-5 text-[22px] font-bold">お問い合わせ</h1>
  <p class="mb-6 text-[15px] leading-[2] text-[var(--muted)]">
    記事内容の誤り・広告に関するお問い合わせなどは、以下のフォームからご連絡ください。
  </p>
  {
    GOOGLE_FORM_EMBED_URL ? (
      <iframe
        src={GOOGLE_FORM_EMBED_URL}
        title="お問い合わせフォーム"
        width="100%"
        height="900"
        style="border: none"
      >
        読み込んでいます…
      </iframe>
    ) : (
      <p class="text-[15px] leading-[2] text-[var(--muted)]">準備中</p>
    )
  }
</BaseLayout>
