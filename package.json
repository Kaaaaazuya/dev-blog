{
  "name": "dev-blog",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "//": "pnpm利用。バージョン固定は `corepack use pnpm@latest` で packageManager フィールドを自動追記",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "astro check",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "7.0.6",
    "mermaid": "^11.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/mdast": "^4.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.0.0",
    "prettier-plugin-astro": "^0.14.0",
    "simple-git-hooks": "^2.0.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.63.0",
    "wrangler": "^4.107.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged && gitleaks git --staged --redact --no-banner",
    "pre-push": "pnpm typecheck"
  },
  "lint-staged": {
    "*.{astro,js,mjs,ts}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "*.{md,json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
