{
  "name": "dev-blog",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "//": "pnpm利用。バージョン固定は `corepack use pnpm@latest` で packageManager フィールドを自動追記",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "textlint": "textlint 'src/content/blog/**/*.md'",
    "test": "vitest run",
    "typecheck": "astro check",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/ibm-plex-sans-jp": "^5.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "7.0.6",
    "mermaid": "^11.0.0",
    "satori": "^0.26.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/mdast": "^4.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.0.0",
    "prettier-plugin-astro": "^0.14.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "simple-git-hooks": "^2.0.0",
    "tailwindcss": "^4.3.2",
    "textlint": "^15.7.1",
    "textlint-filter-rule-comments": "^1.3.0",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "textlint-rule-prh": "^6.1.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged && gitleaks protect --staged --redact --no-banner",
    "pre-push": "pnpm typecheck"
  },
  "lint-staged": {
    "*.{astro,js,mjs,ts}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "*.{md,json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
